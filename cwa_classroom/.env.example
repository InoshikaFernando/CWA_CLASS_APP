# Copy this file to .env and fill in your values
# NEVER commit .env to source control

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# DB_ENGINE=sqlite  → local SQLite (no MySQL needed)
# DB_ENGINE=mysql   → MySQL (default, uses DB_* vars below)
DB_ENGINE=sqlite
DB_NAME=cwa_classroom
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Media storage (set USE_S3=True in production)
USE_S3=False

# AWS S3 (only needed when USE_S3=True)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-2

# Email (Gmail SMTP for production)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@wizardslearninghub.co.nz

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=nzd
