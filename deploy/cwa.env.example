# /etc/cwa/cwa.env — mode 600, owned by cwa
# Copy this file and fill in real values. Never commit secrets.

# Django
SECRET_KEY=generate-with-python-c-from-django.core.management.utils-import-get_random_secret_key-print-get_random_secret_key
DEBUG=False
ALLOWED_HOSTS=wizardslearninghub.co.nz,www.wizardslearninghub.co.nz

# Database — DigitalOcean Managed MySQL
DB_NAME=cwa_classroom
DB_USER=cwa_django
DB_PASSWORD=
DB_HOST=private-db-mysql-syd1-xxxxx-do-user-xxxxx-0.db.ondigitalocean.com
DB_PORT=25060
DB_SSL_CA=/etc/cwa/do-ca.pem

# Redis (cache + sessions + Celery broker)
REDIS_URL=redis://127.0.0.1:6379/0

# Media — DigitalOcean Spaces
USE_S3=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=cwa-media-prod
AWS_S3_REGION_NAME=syd1
AWS_S3_ENDPOINT_URL=https://syd1.digitaloceanspaces.com
AWS_S3_CUSTOM_DOMAIN=cwa-media-prod.syd1.digitaloceanspaces.com

# Email — Resend transactional API (preferred). When RESEND_API_KEY is set the
# app uses the Resend backend; otherwise it falls back to SMTP below, then console.
# Requires the From domain (wizardslearninghub.co.nz) to be verified in Resend.
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@wizardslearninghub.co.nz

# Self-imposed daily send cap. 0 = no cap (send directly, no queue throttling).
# Set a positive number only to stay under a provider's free-tier daily limit.
DAILY_EMAIL_LIMIT=0

# Email — SMTP fallback (used only when RESEND_API_KEY is empty)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Income-vs-expense dashboard (billing admin)
# Read-only DigitalOcean Personal Access Token. When set, sync_vendor_charges
# pulls real monthly DO invoices into expenses (addons included). Empty = no-op.
DIGITALOCEAN_API_TOKEN=
# Optional: override the USD->NZD fallback rate / FX endpoint (live by default).
# USD_TO_NZD_RATE=1.65
# FX_RATE_API_URL=https://api.frankfurter.dev/v1/latest

# Piston (code execution)
PISTON_API_URL=http://10.124.0.x:2000
PISTON_API_TOKEN=

# Site URL (used in email links)
SITE_URL=https://wizardslearninghub.co.nz
